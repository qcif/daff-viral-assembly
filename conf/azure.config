// Azure Batch configuration for wf4 (VIEW workflow)
//
// Load credentials before running:
//   export $(grep -v '^#' .env.azure | xargs)
//
// Required env vars:
//   AZURE_BATCH_ACCESS_KEY
//   AZURE_STORAGE_ACCOUNT_KEY

// Azure Blob work directory (standard storage, auto-cleaned after 14 days)
workDir = 'az://workdata/work'

process {

    // All processes run on Azure Batch to maximize single-node utilisation.
    // Reference data (~830GB) is staged once per node at startup via start task.
    // Pool autoscales 0->1 node; all tasks run on the same node.
    // taskSlotsPerNode=48 allows Nextflow to dispatch up to 48 concurrent tasks.

    executor = 'azurebatch'
    errorStrategy = 'ignore'
    queue = 'view'

    // Mount refdata directory (staged to NVMe by the pool start task).
    // refdata-wf4 databases are a subdirectory: /mnt/nvme/refdata/refdata-wf4/
    containerOptions = "-v /mnt/nvme/refdata:/mnt/nvme/refdata:ro"

    // -----------------------------------------------------------------------
    // Heavy compute: BLAST
    // Needs core_nt (269GB, in /mnt/nvme/refdata)
    // -----------------------------------------------------------------------
    withName: 'MEGABLAST|MEGABLAST_ROUND2|MEGABLAST_TO_REF' {
        cpus = 16
        memory = 64.GB
        maxForks = 2
        time = 4.h
    }

    // -----------------------------------------------------------------------
    // Heavy compute: Kraken2 (315GB DB, memory-mapped)
    // -----------------------------------------------------------------------
    withName: 'KRAKEN2|KRAKEN2_ABUNDANCE_ESTIMATE' {
        cpus = 8
        memory = 340.GB
        maxForks = 1
        time = 4.h
    }

    // -----------------------------------------------------------------------
    // Heavy compute: Kaiju (175GB DB)
    // -----------------------------------------------------------------------
    withName: 'KAIJU' {
        cpus = 8
        memory = 200.GB
        maxForks = 1
        time = 4.h
    }

    // -----------------------------------------------------------------------
    // Assembly: SPAdes (CPU and memory intensive)
    // -----------------------------------------------------------------------
    withName: 'SPADES' {
        cpus = 16
        memory = 64.GB
        maxForks = 2
        time = 8.h
    }

    // -----------------------------------------------------------------------
    // Protein domain search: HMMSCAN (Pfam-A.hmm 1.8GB)
    // -----------------------------------------------------------------------
    withName: 'HMMSCAN' {
        cpus = 8
        memory = 16.GB
        maxForks = 4
        time = 4.h
    }

    // -----------------------------------------------------------------------
    // Viral sequence classification: GeNomad
    // -----------------------------------------------------------------------
    withName: 'GENOMAD_ENDTOEND' {
        cpus = 8
        memory = 32.GB
        maxForks = 4
        time = 4.h
    }

    // -----------------------------------------------------------------------
    // Alignment: BWA
    // -----------------------------------------------------------------------
    withName: 'BWA|MAPPING_BACK_TO_REF|REALIGN' {
        cpus = 8
        memory = 16.GB
        maxForks = 4
        time = 2.h
    }

    // -----------------------------------------------------------------------
    // Lightweight processes: can run many in parallel
    // -----------------------------------------------------------------------
    withName: 'FASTP|FASTQC_RAW|SEQTK_SEQ|SEQTK_SUBSEQ|SAMTOOLS_REF|SAMTOOLS_CONTIGS|SAMTOOLS_MPILEUP|TRIM_ENDS|MOSDEPTH_CONTIGS|MOSDEPTH_REF|PYFAIDX_REF|PYFAIDX_CONTIGS|BCFTOOLS|BEDTOOLS|CDHIT_CDHIT|ORFIPY|RETRIEVE_VIRAL_READS_KRAKEN2|KRAKEN2_TO_KRONA|EXTRACT_REF_FASTA|EXTRACT_BLAST_HITS|FASTA2TABLE_CONTIGS|FASTA2TABLE_REF|SUMMARISE_READ_CLASSIFICATION|SUMMARISE_RESULTS|HTML_ALIGN|HTML_REPORT|QC_REPORT|IDENTIFY_ERRORS' {
        cpus = 2
        memory = 8.GB
        maxForks = 16
        time = 1.h
    }

}

azure {

    storage {
        accountName = 'daffstandard'
        // Key is read automatically from: AZURE_STORAGE_ACCOUNT_KEY
    }

    batch {
        location          = 'australiaeast'
        accountName       = 'daffbatch'
        accountKey        = System.getenv('AZURE_BATCH_ACCESS_KEY')
        autoPoolMode      = false
        allowPoolCreation = false

        copyToolInstallMode     = 'task'
        deleteTasksOnCompletion = false
        deleteJobsOnCompletion  = false
    }
}
