// Azure Batch test configuration for wf4 (VIEW workflow)
//
// Targets the view_test pool (Standard_L4as_v3: 4 vCPU, 32GB RAM, 960GB NVMe).
// Uses small test/mock databases instead of production databases.
//
// Run with:
//   nextflow run main.nf -profile azure_test --input tests/index_test.csv ...

workDir = 'az://workdata/work'

process {

    executor = 'azurebatch'
    errorStrategy = 'ignore'
    queue = 'view_test'

    containerOptions = "-v /mnt/nvme/refdata:/mnt/nvme/refdata:ro"

    // All processes constrained to L4as_v3 resources (4 vCPU, 32GB RAM)
    cpus   = 2
    memory = 8.GB
    time   = 1.h

    // Sequential execution for memory-hungry tools on the small node
    withName: 'KRAKEN2|KRAKEN2_ABUNDANCE_ESTIMATE' {
        cpus     = 4
        memory   = 16.GB
        maxForks = 1
        time     = 2.h
    }

    withName: 'KAIJU' {
        cpus     = 4
        memory   = 16.GB
        maxForks = 1
        time     = 2.h
    }

    withName: 'MEGABLAST|MEGABLAST_ROUND2|MEGABLAST_TO_REF' {
        cpus     = 4
        memory   = 16.GB
        maxForks = 1
        time     = 2.h
    }

    withName: 'SPADES' {
        cpus     = 4
        memory   = 16.GB
        maxForks = 1
        time     = 4.h
    }

}

params {
    // Override DB paths to use test databases on the test node.
    // Ensure these are uploaded to blob storage or included in refdata-wf4.
    kraken2_db   = '/mnt/nvme/refdata/test/kraken_test_db'
    kaiju_db_path = '/mnt/nvme/refdata/test/kaiju_test_db'
    kaiju_dbname = 'kaiju_db.fmi'
}

azure {

    storage {
        accountName = 'daffstandard'
    }

    batch {
        location          = 'australiaeast'
        accountName       = 'daffbatch'
        accountKey        = System.getenv('AZURE_BATCH_ACCESS_KEY')
        autoPoolMode      = false
        allowPoolCreation = false

        copyToolInstallMode     = 'task'
        deleteTasksOnCompletion = false
        deleteJobsOnCompletion  = false
    }
}
