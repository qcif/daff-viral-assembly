includeConfig 'conf/base.config'
params.validationSkipDuplicateCheck = true
params.validationS3PathCheck = false

includeConfig 'conf/modules.config'

params {
  input = 'index.csv'
  analyst_name = null
  facility = null
  outdir = 'results'
  help = false
  tool_versions = "${projectDir}/versions.yml"
  default_params = "${projectDir}/params/default_params.yml"
  rrna_ref = null
  filter_terms = "${projectDir}/bin/filterKeyWords.txt"
  phix = "${projectDir}/db/phiX174.fasta"
  kraken2_db = null
  kaiju_db = null
  genomad_db = null
  hmmer_db = null
  prot_db = null
  save_trimmed_fail = false
  save_merged = false
  publish_dir_mode = 'copy'
  qfiltered_reads_threshold = 8000000
  clean_reads_threshold = 2500000
  blast_threads = 2
  blastn_db = null
  taxdump = null
  kraken2_save_classified_reads = false
  kraken2_save_unclassified_reads = true
  kraken2_save_readclassifications = true
  subsample_enabled = true
  subsample_size = 40000000
  rvdb_taxonomy = null
  trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
  download_databases = false
  databases = "${launchDir}/databases"
}

process {
  withName: /HTML_ALIGN|FASTA2TABLE_CONTIGS|FASTA2TABLE_REF|EXTRACT_BLAST_HITS|EXTRACT_VIRAL_BLAST_HITS|REF_COVSTATS|QC_REPORT|SUMMARISE_READ_CLASSIFICATION|SUMMARISE_RESULTS|NOVELS|CONTIG_COVSTATS|KRAKEN2_ABUNDANCE_ESTIMATE|IDENTIFY_ERRORS|EXTRACT_VIRAL_BLAST_HITS_ROUND2/ {
    container = "docker.io/gauthiem/daff-viral-assembly:1.01"
  }
  withName: /MEGABLAST|MEGABLAST_ROUND2|MEGABLAST_TO_REF/ {
    container = "quay.io/biocontainers/blast:2.16.0--h66d330f_4"
  }
  withName: /SAMTOOLS_REF|SAMTOOLS_CONTIGS|SAMTOOLS_MPILEUP|TRIM_ENDS/ {
    container = "quay.io/biocontainers/samtools:1.22.1--h96c455f_0"
  }
  withName: /MOSDEPTH_CONTIGS|MOSDEPTH_REF/ {
    container = "quay.io/biocontainers/mosdepth:0.3.3--h37c5b7d_2"
  }
  withName: /PYFAIDX_REF|PYFAIDX_CONTIGS/ {
    container = "quay.io/biocontainers/pyfaidx:0.8.1.3--pyhdfd78af_0"
  }
  withName: /REALIGN|BWA|MAPPING_BACK_TO_REF/ {
    container = "quay.io/biocontainers/bwa:0.7.19--h577a1d6_1"
  }
  withName: /KRONA_KTIMPORTTEXT|KRAKEN2_TO_KRONA/ {
    container = "quay.io/biocontainers/krona:2.8.1--pl5321hdfd78af_1"
  }
  withName: /SEQTK_SEQ|SEQTK_SUBSEQ/ {
    container = "quay.io/biocontainers/seqtk:1.3--h7132678_4"
  }
  withName: BCFTOOLS { container = "quay.io/biocontainers/bcftools:1.19--h8b25389_0" }
  withName: BEDTOOLS { container = "quay.io/biocontainers/bedtools:2.27.1--h077b44d_9" }
  withName: CDHIT_CDHIT { container = "quay.io/biocontainers/cd-hit:4.8.1--h5ca1c30_13" }
  withName: EXTRACT_REF_FASTA { container = "quay.io/biocontainers/entrez-direct:22.4--he881be0_0" }
  withName: FASTP { container = "quay.io/biocontainers/fastp:1.0.1--heae3180_0" }
  withName: FASTQC_RAW { container = "quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0" }
  withName: /GENOMAD_ENDTOEND|DOWNLOAD_GENOMAD_DB/ { container = "quay.io/biocontainers/genomad:1.11.2--pyhdfd78af_0" }
  withName: HMMSCAN { container = "quay.io/biocontainers/hmmer:3.4--hb6cb901_4" }
  withName: HTML_REPORT { container = "docker://neoformit/daff-ont-assembly" }
  withName: ORFIPY { container = "quay.io/biocontainers/orfipy:0.0.4--py311he264feb_4" }
  withName: RETRIEVE_VIRAL_READS_KRAKEN2 { container = "quay.io/biocontainers/krakentools:1.2.1--pyh7e72e81_0" }
  }

// Nextflow plugins
plugins {
    id 'nf-validation@1.1.4' // Validation of pipeline parameters and creation of an input channel from a sample sheet
}

profiles {
  docker {
    docker.enabled = true
    singularity.enabled = false
  }
  singularity {
    singularity.enabled = true
    singularity.autoMounts = true
    docker.enabled = false
    singularity.runOptions = "--bind ${projectDir}:${projectDir}"
  }

  test {
    includeConfig "conf/test.config"
  }
  azure {
    docker.enabled = true
    singularity.enabled = false
    includeConfig "conf/azure.config"
  }
  azure_test {
    docker.enabled = true
    singularity.enabled = false
    includeConfig "conf/azure.config"
    includeConfig "conf/azure.test.config"
  }
}

singularity.registry = 'quay.io'

timeline {
    enabled = true
    file    = "${params.outdir}/01_pipeline_logs/execution_timeline_${params.trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/01_pipeline_logs/execution_report_${params.trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/01_pipeline_logs/execution_trace_${params.trace_timestamp}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/01_pipeline_logs/pipeline_dag_${params.trace_timestamp}.html"
}

manifest {
    name            = 'VIEW'
    author          = 'collaboration between QUT eResearch and QCIF'
    homePage        = 'https://github.com/qcif/daff-viral-aseembly'
    description     = 'daff-viral-assembly'
    mainScript      = 'main.nf'
    nextflowVersion = '>=26.04.1'
    defaultBranch   = 'main'
}
